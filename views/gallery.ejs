        <td class="px-4 py-3 text-sm text-gray-400">${formatGalleryDate(video.upload_date || video.created_at)}</td>
        <td class="px-4 py-3 text-right">
          <div class="flex items-center justify-end gap-1">
            <button class="file-rename-btn p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-white transition-colors" data-video-id="${escapeHtml(video.id)}" data-video-title="${title}">
              <i class="ti ti-pencil text-sm"></i>
            </button>
            <button class="file-delete-btn p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-red-400 transition-colors" data-video-id="${escapeHtml(video.id)}" data-video-title="${title}">
              <i class="ti ti-trash text-sm"></i>
            </button>
          </div>
        </td>
      </tr>
    `;
  }

  function bindGalleryItemInteractions() {
    document.querySelectorAll('.gallery-playable').forEach(item => {
      item.onclick = () => playMedia(item.dataset.id, item.dataset.mediaTitle, item.dataset.mediaType);
    });

    document.querySelectorAll('.gallery-folder-link').forEach(item => {
      item.onclick = () => { window.location.href = `/gallery?folder=${encodeURIComponent(item.dataset.folderId)}`; };
    });

    document.querySelectorAll('.file-rename-btn').forEach(button => {
      button.onclick = (event) => {
        event.preventDefault();
        event.stopPropagation();
        showRenameDialog(button.dataset.videoId, button.dataset.videoTitle);
      };
    });

    document.querySelectorAll('.file-delete-btn').forEach(button => {
      button.onclick = (event) => {
        event.preventDefault();
        event.stopPropagation();
        showDeleteDialog(button.dataset.videoId, button.dataset.videoTitle);
      };
    });

    document.querySelectorAll('.folder-rename-btn').forEach(button => {
      button.onclick = (event) => {
        event.preventDefault();
        event.stopPropagation();
        showRenameFolderDialog(button.dataset.folderId, button.dataset.folderName);
      };
    });

    document.querySelectorAll('.folder-delete-btn').forEach(button => {
      button.onclick = (event) => {
        event.preventDefault();
        event.stopPropagation();
        showDeleteFolderDialog(button.dataset.folderId, button.dataset.folderName);
      };
    });

    document.querySelectorAll('.file-item, .file-item-row').forEach(item => {
      item.addEventListener('dragstart', (event) => {
        event.dataTransfer.setData('text/plain', item.dataset.id);
        event.dataTransfer.effectAllowed = 'move';
        item.classList.add('opacity-60');
      });
      item.addEventListener('dragend', () => {
        item.classList.remove('opacity-60');
      });
    });

    document.querySelectorAll('.folder-drop-target').forEach(target => {
      target.addEventListener('dragover', (event) => {
        event.preventDefault();
        target.classList.add('border-primary', 'bg-primary/5');
      });
      target.addEventListener('dragleave', () => {
        target.classList.remove('border-primary', 'bg-primary/5');
      });
      target.addEventListener('drop', async (event) => {
        event.preventDefault();
        target.classList.remove('border-primary', 'bg-primary/5');
        const videoId = event.dataTransfer.getData('text/plain');
        if (videoId) {
          await moveVideoToFolder(videoId, target.dataset.folderId);
        }
      });
    });

    const rootDropZone = document.getElementById('rootDropZone');
    if (rootDropZone) {
      rootDropZone.ondragover = (event) => {
        event.preventDefault();
        rootDropZone.classList.add('border-primary', 'bg-primary/5', 'text-white');
      };
      rootDropZone.ondragleave = () => {
        rootDropZone.classList.remove('border-primary', 'bg-primary/5', 'text-white');
      };
      rootDropZone.ondrop = async (event) => {
        event.preventDefault();
        rootDropZone.classList.remove('border-primary', 'bg-primary/5', 'text-white');
        const videoId = event.dataTransfer.getData('text/plain');
        if (videoId) {
          await moveVideoToFolder(videoId, null);
        }
      };
    }
  }

  function renderGalleryContent() {
    const content = document.getElementById('galleryContent');
    const paginationBar = document.getElementById('galleryPaginationBar');
    if (!content) return;

    const hasRootFolders = !currentFolderId && galleryFoldersState.length > 0;
    const totalItems = galleryVideosState.length + (hasRootFolders ? galleryFoldersState.length : 0);

    if (totalItems === 0) {
      content.innerHTML = `
        <div class="text-center py-12">
          <div class="w-16 h-16 rounded-full bg-dark-700 flex items-center justify-center mx-auto mb-4">
            <i class="ti ti-video text-gray-500 text-2xl"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-300 mb-2">No items yet</h3>
          <p class="text-gray-500 text-sm mb-4">Upload your first media or create a folder to get started</p>
          <button onclick="openUploadModal()" class="inline-flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors">
            <i class="ti ti-upload"></i>
            <span>Upload Media</span>
          </button>
        </div>
      `;
      if (paginationBar) paginationBar.classList.add('hidden');
      applyGalleryViewMode();
      return;
    }

    const folderGridMarkup = hasRootFolders ? galleryFoldersState.map(buildFolderGridMarkup).join('') : '';
    const folderListMarkup = hasRootFolders ? galleryFoldersState.map(buildFolderListMarkup).join('') : '';
    const videoGridMarkup = galleryVideosState.map(buildVideoGridMarkup).join('');
    const videoListMarkup = galleryVideosState.map(buildVideoListMarkup).join('');

    content.innerHTML = `
      <div id="gridView" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 ${currentView === 'list' ? 'hidden' : ''}">
        ${folderGridMarkup}${videoGridMarkup}
      </div>
      <div id="listView" class="${currentView === 'list' ? '' : 'hidden'}">
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead class="bg-gray-700">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Name</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-24">Duration</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-28">Size</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-32">Modified</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-300 uppercase tracking-wider w-24">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
              ${folderListMarkup}${videoListMarkup}
            </tbody>
          </table>
        </div>
      </div>
    `;

    if (paginationBar) paginationBar.classList.remove('hidden');
    bindGalleryItemInteractions();
    syncGalleryCollections();
    applyGalleryViewMode();
    filterAndSort();
  }

  let gridItems = [];
  let listItems = [];
  const itemsPerPage = 18;
  let currentPage = 1;
  let filteredGridItems = [];
  let filteredListItems = [];

  function syncGalleryCollections() {
    gridItems = Array.from(document.querySelectorAll('.gallery-grid-item'));
    listItems = Array.from(document.querySelectorAll('.gallery-list-item'));
  }

  function getItemData(item) {
    return {
      id: item.dataset.id,
      title: item.dataset.title || '',
      date: new Date(item.dataset.date || 0).getTime(),
      size: parseInt(item.dataset.size) || 0,
      type: item.dataset.type || 'video',
      kind: item.dataset.kind || 'file'
    };
  }

  function filterAndSort() {
    const search = searchInput ? searchInput.value.toLowerCase() : '';
    const sort = sortSelect ? sortSelect.value : 'newest';
    const typeFilter = document.getElementById('typeFilter');
    const type = typeFilter ? typeFilter.value : 'all';
    
    const filterFn = (item) => {
      const data = getItemData(item);
      const matchesSearch = data.title.toLowerCase().includes(search);
      const matchesType = data.kind === 'folder'
        ? type === 'all'
        : type === 'all' || data.type === type;
      return matchesSearch && matchesType;
    };

    const sortFn = (a, b) => {
      const dataA = getItemData(a);
      const dataB = getItemData(b);

      if (dataA.kind !== dataB.kind) {
        return dataA.kind === 'folder' ? -1 : 1;
      }
      
      switch (sort) {
        case 'oldest':
          return dataA.date - dataB.date;
        case 'newest':
          return dataB.date - dataA.date;
        case 'name':
          return dataA.title.localeCompare(dataB.title);
        case 'size':
          return dataB.size - dataA.size;
        default:
          return dataB.date - dataA.date;
      }
    };

    syncGalleryCollections();
    filteredGridItems = [...gridItems].filter(filterFn).sort(sortFn);
    filteredListItems = [...listItems].filter(filterFn).sort(sortFn);

    const gridContainer = document.getElementById('gridView');
    const listContainer = document.querySelector('#listView tbody');
    
    filteredGridItems.forEach(item => gridContainer.appendChild(item));
    filteredListItems.forEach(item => listContainer.appendChild(item));

    currentPage = 1;
    renderPage();
  }

  function renderPage() {
    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    
    gridItems.forEach(item => item.style.display = 'none');
    listItems.forEach(item => item.style.display = 'none');
    
    filteredGridItems.slice(start, end).forEach(item => item.style.display = '');
    filteredListItems.slice(start, end).forEach(item => item.style.display = '');
    
    const totalItems = filteredGridItems.length;
    const info = document.getElementById('paginationInfo');
    if (info) info.textContent = totalItems > 0 ? `Showing ${start + 1}-${Math.min(end, totalItems)} of ${totalItems} items` : 'No items found';
    
    renderPagination();
  }

  function renderPagination() {
    const container = document.getElementById('paginationControls');
    if (!container) return;
    const totalPages = Math.ceil(filteredGridItems.length / itemsPerPage);
    container.innerHTML = '';
    
    if (totalPages <= 1) return;
    
    const prev = document.createElement('button');
    prev.className = `w-9 h-9 flex items-center justify-center rounded-lg ${currentPage === 1 ? 'bg-dark-700 text-gray-600 cursor-not-allowed' : 'bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors'}`;
    prev.innerHTML = '<i class="ti ti-chevron-left"></i>';
    prev.disabled = currentPage === 1;
    prev.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderPage(); } });
    container.appendChild(prev);

    let startPage = Math.max(1, currentPage - 2);
    let endPage = Math.min(totalPages, startPage + 4);
    if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);

    for (let i = startPage; i <= endPage; i++) {
      const btn = document.createElement('button');
      btn.className = `w-9 h-9 flex items-center justify-center rounded-lg ${i === currentPage ? 'bg-primary text-white' : 'bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors'}`;
      btn.textContent = i;
      btn.addEventListener('click', () => { currentPage = i; renderPage(); });
      container.appendChild(btn);
    }

    const next = document.createElement('button');
    next.className = `w-9 h-9 flex items-center justify-center rounded-lg ${currentPage === totalPages ? 'bg-dark-700 text-gray-600 cursor-not-allowed' : 'bg-dark-700 hover:bg-dark-600 text-gray-400 hover:text-white transition-colors'}`;
    next.innerHTML = '<i class="ti ti-chevron-right"></i>';
    next.disabled = currentPage === totalPages;
    next.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; renderPage(); } });
    container.appendChild(next);
  }

  if (searchInput) searchInput.addEventListener('input', filterAndSort);
  if (sortSelect) sortSelect.addEventListener('change', filterAndSort);
  const typeFilter = document.getElementById('typeFilter');
  if (typeFilter) typeFilter.addEventListener('change', filterAndSort);

  window.refreshGalleryData = async function() {
    try {
      const params = new URLSearchParams();
      if (currentFolderId) {
        params.set('folder', currentFolderId);
      }
      const response = await fetch(`/api/gallery/data?${params.toString()}`);
      const data = await response.json();
      if (!data.success) {
        throw new Error(data.error || 'Failed to refresh gallery');
      }
      galleryVideosState = data.videos || [];
      galleryFoldersState = data.folders || [];
      galleryCurrentFolderState = data.currentFolder || null;
      currentPage = 1;
      renderGalleryContent();
      loadDiskUsage();
    } catch (error) {
      console.error('Error refreshing gallery:', error);
      showToast('error', error.message || 'Failed to refresh gallery');
    }
  };

  initializeGalleryViewButtons();
  bindGalleryItemInteractions();
  syncGalleryCollections();
  if (gridItems.length > 0) filterAndSort();
});
</script>

